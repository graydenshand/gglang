MAP x=:x, y=:y, color=:species
GEOM POINT
TITLE "Iris — custom theme"
XLABEL "Sepal length"
YLABEL "Sepal width"
THEME {
    title_font_size = 40,
    axis_label_font_size = 32,
    tick_label_font_size = 32,
    axis_color = "#888888",
    title_height = 60,
    y_gutter_width = 100,
    x_gutter_height = 100,
    window_margin = 100
}
